<?xml version="1.0"?>
<phpunit
	bootstrap="tests/bootstrap-sqlite.php"
	backupGlobals="false"
	colors="true"
	convertErrorsToExceptions="true"
	convertNoticesToExceptions="true"
	convertWarningsToExceptions="true"
>
	<testsuites>
		<testsuite name="Relevanssi Light tests">
			<directory suffix=".php">tests</directory>
			<exclude>tests/wp-tests-config-sqlite.php</exclude>
			<exclude>tests/bootstrap-sqlite.php</exclude>
			<exclude>tests/bootstrap.php</exclude>
		</testsuite>
	</testsuites>
	<php>
		<env name="WP_TESTS_DIR" value="/tmp/wordpress-tests-lib"/>
		<env name="WP_CORE_DIR" value="/tmp/wordpress/"/>
	</php>
</phpunit>
